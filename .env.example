# Core
BETTER_AUTH_SECRET=replace-with-a-random-secret
BETTER_AUTH_URL=https://zeroroku.example.com
NUXT_PUBLIC_SITE_URL=https://zeroroku.example.com
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:6066,http://127.0.0.1:6066

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/zeroroku
REDIS_URL=redis://localhost:6379
AUTH_SIGN_IN_RATE_LIMIT_WINDOW_MS=10000
AUTH_SIGN_IN_RATE_LIMIT_MAX=3
AUTH_SIGN_IN_IDENTIFIER_RATE_LIMIT_WINDOW_MS=10000
AUTH_SIGN_IN_IDENTIFIER_RATE_LIMIT_MAX=3
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=60000
AUTH_PASSWORD_RESET_RATE_LIMIT_MAX=3
AUTH_PASSWORD_RESET_EMAIL_COOLDOWN_MS=300000

# GitHub OAuth
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# Amazon SES for password reset emails
AUTH_EMAIL_FROM=noreply@example.com
AUTH_EMAIL_AWS_REGION=us-east-1
AUTH_EMAIL_APP_NAME=ZeroRoku

# AWS credentials
# If you use an IAM role on the server, you can leave these unset.
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
# AWS_SESSION_TOKEN=replace-with-aws-session-token

# Afdian
AFDIAN_USER_ID=replace-with-afdian-user-id
AFDIAN_TOKEN=replace-with-afdian-token
